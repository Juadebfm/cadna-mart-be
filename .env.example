# Application
NODE_ENV=dev
APP_PORT=3000
APP_NAME=cadna-mart-backend
API_PREFIX=api
API_DEFAULT_VERSION=1

# Database
MONGO_URI=mongodb://cadna_admin:cadna_secret@localhost:27017/cadna_mart_dev?authSource=admin

# JWT
JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long
JWT_REFRESH_EXPIRATION=7d

# Session
SESSION_SECRET=your-session-secret-minimum-32-characters-long
SESSION_MAX_AGE=86400000

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
