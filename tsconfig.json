{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@config/*": ["src/config/*"],
      "@database/*": ["src/database/*"],
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@common/*": ["src/common/*"],
      "@logger/*": ["src/logger/*"],
      "@health/*": ["src/health/*"],
      "@shared/*": ["src/shared/*"],
      "@otp/*": ["src/otp/*"],
      "@email/*": ["src/email/*"],
      "@registration-session/*": ["src/registration-session/*"],
      "@categories/*": ["src/categories/*"],
      "@products/*": ["src/products/*"],
      "@stores/*": ["src/stores/*"],
      "@reviews/*": ["src/reviews/*"],
      "@banners/*": ["src/banners/*"],
      "@home/*": ["src/home/*"],
      "@cart/*": ["src/cart/*"],
      "@wishlist/*": ["src/wishlist/*"],
      "@shipping/*": ["src/shipping/*"],
      "@policies/*": ["src/policies/*"],
      "@newsletter/*": ["src/newsletter/*"],
      "@search/*": ["src/search/*"],
      "@site-config/*": ["src/site-config/*"]
    }
  }
}
