{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@config/(.*)$": "<rootDir>/../src/config/$1",
    "^@database/(.*)$": "<rootDir>/../src/database/$1",
    "^@auth/(.*)$": "<rootDir>/../src/auth/$1",
    "^@users/(.*)$": "<rootDir>/../src/users/$1",
    "^@common/(.*)$": "<rootDir>/../src/common/$1",
    "^@logger/(.*)$": "<rootDir>/../src/logger/$1",
    "^@health/(.*)$": "<rootDir>/../src/health/$1",
    "^@shared/(.*)$": "<rootDir>/../src/shared/$1",
    "^@otp/(.*)$": "<rootDir>/../src/otp/$1",
    "^@email/(.*)$": "<rootDir>/../src/email/$1",
    "^@registration-session/(.*)$": "<rootDir>/../src/registration-session/$1",
    "^@categories/(.*)$": "<rootDir>/../src/categories/$1",
    "^@products/(.*)$": "<rootDir>/../src/products/$1",
    "^@sellers/(.*)$": "<rootDir>/../src/sellers/$1",
    "^@reviews/(.*)$": "<rootDir>/../src/reviews/$1",
    "^@banners/(.*)$": "<rootDir>/../src/banners/$1",
    "^@home/(.*)$": "<rootDir>/../src/home/$1",
    "^@cart/(.*)$": "<rootDir>/../src/cart/$1",
    "^@wishlist/(.*)$": "<rootDir>/../src/wishlist/$1",
    "^@shipping/(.*)$": "<rootDir>/../src/shipping/$1",
    "^@policies/(.*)$": "<rootDir>/../src/policies/$1",
    "^@newsletter/(.*)$": "<rootDir>/../src/newsletter/$1",
    "^@search/(.*)$": "<rootDir>/../src/search/$1",
    "^@site-config/(.*)$": "<rootDir>/../src/site-config/$1",
    "^@upload/(.*)$": "<rootDir>/../src/upload/$1",
    "^@admin/(.*)$": "<rootDir>/../src/admin/$1",
    "^@addresses/(.*)$": "<rootDir>/../src/addresses/$1",
    "^@auth-events/(.*)$": "<rootDir>/../src/auth-events/$1",
    "^@data-requests/(.*)$": "<rootDir>/../src/data-requests/$1",
    "^@brands/(.*)$": "<rootDir>/../src/brands/$1",
    "^@collections/(.*)$": "<rootDir>/../src/collections/$1"
  }
}
